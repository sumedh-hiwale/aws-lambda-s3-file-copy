{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::sumedh-source-bucket-12345",
        "arn:aws:s3:::sumedh-source-bucket-12345/*",
        "arn:aws:s3:::sumedh-destination-bucket-12345",
        "arn:aws:s3:::sumedh-destination-bucket-12345/*"
      ]
    }
  ]
}
